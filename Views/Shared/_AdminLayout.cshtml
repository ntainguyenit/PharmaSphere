<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="admin-layout">
        <aside class="sidebar">
            <div class="sidebar-logo">Admin Panel</div>
            <ul class="sidebar-menu">
                <li class="sidebar-item active">
                    <a href="/Admin">
                        <i data-lucide="layout-dashboard"></i>
                        Dashboard
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="#">
                        <i data-lucide="package"></i>
                        Quản lý sản phẩm
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="#">
                        <i data-lucide="file-text"></i>
                        Quản lý hóa đơn
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="#">
                        <i data-lucide="users"></i>
                        Quản lý khách hàng
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="#">
                        <i data-lucide="user-cog"></i>
                        Quản lý nhân viên
                    </a>
                </li>
                <li class="sidebar-item">
                    <a href="#">
                        <i data-lucide="bar-chart-2"></i>
                        Thống kê
                    </a>
                </li>
                <li style="margin-top: auto;">
                    <a href="#" style="color: rgba(255,255,255,0.5);">
                        <i data-lucide="settings"></i>
                        Cài đặt
                    </a>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <header class="admin-header">
                <div class="search-bar" style="margin: 0; max-width: 400px;">
                    <i data-lucide="search" class="search-icon"></i>
                    <input type="text" placeholder="Tìm kiếm..." />
                </div>
                <div style="display: flex; align-items: center; gap: 1.5rem;">
                    <i data-lucide="bell" style="cursor: pointer; position: relative;">
                        <span style="position: absolute; top: 0; right: 0; width: 8px; height: 8px; background: var(--accent-red); border-radius: 50%;"></span>
                    </i>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="text-align: right;">
                            <div style="font-weight: 700; font-size: 0.9rem;">Nguyễn Văn A</div>
                            <div style="font-size: 0.75rem; color: var(--light-text);">Pharmacist Lead</div>
                        </div>
                        <img src="https://i.pravatar.cc/150?u=admin" style="width: 40px; height: 40px; border-radius: 50%;" />
                    </div>
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    <script>
        lucide.createIcons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
