@model PharmaSphere.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PharmaSphere</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --primary-green: #7BCFA6;
            --primary-green-dark: #0d6849;
            --soft-green: #DFF5E8;
            --accent-red: #E74C3C;
            --dark-text: #1F2937;
            --light-text: #6B7280;
            --white: #FFFFFF;
            --border-color: #E5E7EB;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Inter', sans-serif;
            overflow: hidden;
        }

        .login-wrapper {
            height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            /* Improved background with lower opacity gradient to see the image */
            background: linear-gradient(135deg, rgba(13, 104, 73, 0.7), rgba(13, 104, 73, 0.85)), 
                        url('https://images.unsplash.com/photo-1587854692152-cbe660dbbb88?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
        }

        .login-card {
            width: 100%;
            max-width: 550px; /* Increased width */
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(15px);
            padding: 4rem; /* Increased padding */
            border-radius: 40px; /* More rounded */
            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.35);
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo-box {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            background: var(--soft-green);
            border-radius: 20px;
            color: var(--primary-green-dark);
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 2rem;
            position: relative;
        }

        .form-group label {
            display: block;
            font-weight: 800;
            font-size: 0.9rem;
            margin-bottom: 0.75rem;
            color: var(--dark-text);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper i {
            position: absolute;
            left: 1.5rem;
            color: var(--primary-green-dark);
            width: 20px;
            height: 20px;
            z-index: 2;
            pointer-events: none;
        }

        .form-control {
            width: 100%;
            padding: 1.1rem 1.5rem 1.1rem 3.75rem; /* Icon space on the left */
            border: 2px solid var(--border-color);
            border-radius: 20px;
            font-size: 1.05rem;
            outline: none;
            transition: all 0.3s ease;
            box-sizing: border-box;
            background: #fcfdfd;
            font-weight: 500;
        }

        .form-control:focus {
            border-color: var(--primary-green-dark);
            background: white;
            box-shadow: 0 0 0 6px rgba(13, 104, 73, 0.12);
            transform: translateY(-1px);
        }

        .btn-submit {
            width: 100%;
            padding: 1.25rem;
            background: var(--primary-green-dark);
            color: white;
            border: none;
            border-radius: 20px;
            font-weight: 800;
            font-size: 1.15rem;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 1.5rem;
            box-shadow: 0 10px 20px rgba(13, 104, 73, 0.25);
        }

        .btn-submit:hover {
            background: #0a523a;
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(13, 104, 73, 0.35);
        }

        .text-danger {
            color: var(--accent-red);
            font-size: 0.9rem;
            margin-top: 0.5rem;
            display: block;
            font-weight: 700;
        }

        .back-to-home {
            position: absolute;
            top: 3rem;
            left: 3rem;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 800;
            transition: all 0.3s;
            padding: 0.75rem 1.5rem;
            border-radius: 99px;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
        }

        .back-to-home:hover {
            background: rgba(255,255,255,0.25);
            transform: translateX(-8px);
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <a href="/" class="back-to-home">
            <i data-lucide="arrow-left"></i> Quay lại trang chủ
        </a>

        <div class="login-card">
            <div style="text-align: center;">
                <div class="logo-box">
                    <i data-lucide="pill" style="width: 40px; height: 40px;"></i>
                </div>
                <h2 style="font-size: 2.5rem; font-weight: 900; color: var(--dark-text); margin: 0; letter-spacing: -0.04em;">Chào mừng trở lại</h2>
                <p style="color: var(--light-text); margin: 0.75rem 0 3rem; font-weight: 600; font-size: 1.1rem;">Vui lòng đăng nhập để tiếp tục</p>
            </div>

            <form asp-area="Customer" asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 2rem; text-align: center;"></div>

                <div class="form-group">
                    <label>Tên đăng nhập</label>
                    <div class="input-wrapper">
                        <i data-lucide="user"></i>
                        <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập (VD: user1)" autocomplete="off" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>Mật khẩu</label>
                    <div class="input-wrapper">
                        <i data-lucide="lock"></i>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu của bạn" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
                    <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-size: 1rem; font-weight: 600; color: var(--dark-text);">
                        <input asp-for="RememberMe" type="checkbox" style="width: 20px; height: 20px; accent-color: var(--primary-green-dark);" />
                        Ghi nhớ đăng nhập
                    </label>
                    <a href="#" style="font-size: 1rem; color: var(--primary-green-dark); text-decoration: none; font-weight: 800; border-bottom: 2px solid var(--soft-green);">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn-submit">Đăng nhập ngay</button>
            </form>

            <div style="text-align: center; margin-top: 3.5rem; font-size: 1.1rem; color: var(--light-text); font-weight: 600;">
                Chưa có tài khoản? <a href="/Account/Register" style="color: var(--primary-green-dark); text-decoration: none; font-weight: 900; border-bottom: 3px solid var(--soft-green); margin-left: 0.5rem;">Đăng ký ngay</a>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
