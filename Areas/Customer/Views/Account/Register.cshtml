@model PharmaSphere.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PharmaSphere</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --primary-green: #10B981;
            --primary-dark: #064E3B;
            --primary-light: #D1FAE5;
            --accent: #F59E0B;
            --bg-white: #FFFFFF;
            --bg-soft: #F9FAFB;
            --text-main: #111827;
            --text-muted: #6B7280;
            --border: #E5E7EB;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body, html {
            height: 100%;
            font-family: 'Inter', sans-serif;
            overflow: hidden;
            background-color: var(--bg-soft);
        }

        .register-container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* Left Panel Styles */
        .left-panel {
            flex: 1.2;
            position: relative;
            background: linear-gradient(rgba(6, 78, 59, 0.7), rgba(6, 78, 59, 0.9)), 
                        url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 4rem;
            color: white;
            animation: slideInLeft 1s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes slideInLeft {
            from { transform: translateX(-100%); }
            to { transform: translateX(0); }
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo-icon {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            padding: 0.75rem;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .logo-text {
            font-size: 1.5rem;
            font-weight: 900;
            letter-spacing: -0.02em;
        }

        .welcome-content {
            max-width: 500px;
        }

        .welcome-content h1 {
            font-size: 3.5rem;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            letter-spacing: -0.04em;
        }

        .welcome-content p {
            font-size: 1.25rem;
            line-height: 1.6;
            opacity: 0.9;
            font-weight: 400;
        }

        /* Right Panel Styles */
        .right-panel {
            flex: 1;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
            position: relative;
            animation: fadeIn 1s ease-out;
            overflow-y: auto;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .back-home {
            position: absolute;
            top: 2rem;
            right: 4rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s;
        }

        .back-home:hover {
            color: var(--primary-green);
            transform: translateX(-5px);
        }

        .form-header {
            margin-bottom: 2.5rem;
        }

        .form-header h2 {
            font-size: 2.25rem;
            font-weight: 900;
            color: var(--text-main);
            letter-spacing: -0.03em;
            margin-bottom: 0.5rem;
        }

        .form-header p {
            color: var(--text-muted);
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group label {
            display: block;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.4rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .input-box {
            position: relative;
            width: 100%;
        }

        .input-box i, .input-box svg {
            position: absolute;
            left: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            transition: color 0.3s;
            z-index: 10;
            pointer-events: none;
            display: flex;
            align-items: center;
        }

        .form-control {
            width: 100%;
            padding: 0.875rem 1.25rem 0.875rem 3.5rem;
            border: 2px solid var(--border);
            border-radius: 14px;
            font-size: 1rem;
            font-family: inherit;
            font-weight: 500;
            transition: all 0.3s;
            outline: none;
            background: var(--bg-soft);
        }

        .form-control:focus {
            border-color: var(--primary-green);
            background: white;
            box-shadow: 0 0 0 4px var(--primary-light);
        }

        .btn-register {
            width: 100%;
            padding: 1rem;
            background: var(--primary-dark);
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 8px 16px rgba(6, 78, 59, 0.2);
            margin-top: 1rem;
            margin-bottom: 1.5rem;
        }

        .btn-register:hover {
            background: #065f46;
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(6, 78, 59, 0.3);
        }

        .login-link {
            text-align: center;
            font-size: 1rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .login-link a {
            color: var(--primary-green);
            text-decoration: none;
            font-weight: 800;
            margin-left: 0.5rem;
        }

        .text-danger {
            color: #EF4444;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 0.25rem;
            display: block;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .left-panel {
                display: none;
            }
            .register-container {
                justify-content: center;
                align-items: center;
                background: var(--bg-soft);
            }
            .right-panel {
                max-width: 550px;
                border-radius: 32px;
                height: auto;
                box-shadow: var(--shadow-lg);
                padding: 3rem 2rem;
            }
            body {
                overflow: auto;
            }
        }
    </style>
</head>
<body>
    <div class="register-container">
        <!-- Left Section -->
        <div class="left-panel">
            <div class="logo-section">
                <div class="logo-icon">
                    <i data-lucide="pill" style="width: 28px; height: 28px; color: white;"></i>
                </div>
                <span class="logo-text">PharmaSphere</span>
            </div>

            <div class="welcome-content">
                <h1>Tham gia cùng chúng tôi</h1>
                <p>Tạo tài khoản ngay để nhận được những ưu đãi đặc biệt và trải nghiệm dịch vụ chăm sóc sức khỏe tốt nhất.</p>
            </div>

            <div style="opacity: 0.8; font-weight: 500;">
                © @DateTime.Now.Year PharmaSphere — Smart Pharmacy System
            </div>
        </div>

        <!-- Right Section -->
        <div class="right-panel">
            <a href="/" class="back-home">
                <i data-lucide="arrow-left" style="width: 18px; height: 18px;"></i>
                Về trang chủ
            </a>

            <div class="form-header">
                <h2>Tạo tài khoản</h2>
                <p>Cung cấp thông tin bên dưới để đăng ký</p>
            </div>

            <form asp-area="Customer" asp-controller="Account" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1rem;"></div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Họ và tên</label>
                        <div class="input-box">
                            <i data-lucide="user" style="width: 18px; height: 18px;"></i>
                            <input asp-for="FullName" class="form-control" placeholder="Họ và tên" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Địa chỉ Email</label>
                        <div class="input-box">
                            <i data-lucide="mail" style="width: 18px; height: 18px;"></i>
                            <input asp-for="Email" class="form-control" placeholder="Email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label>Tên đăng nhập</label>
                    <div class="input-box">
                        <i data-lucide="at-sign" style="width: 18px; height: 18px;"></i>
                        <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" autocomplete="off" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-box">
                            <i data-lucide="lock" style="width: 18px; height: 18px;"></i>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Xác nhận</label>
                        <div class="input-box">
                            <i data-lucide="shield-check" style="width: 18px; height: 18px;"></i>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                        </div>
                    </div>
                </div>
                <div style="margin-bottom: 1rem;">
                    <span asp-validation-for="Password" class="text-danger"></span>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-register">Đăng ký tài khoản</button>
            </form>

            <div class="login-link">
                Đã có tài khoản? <a href="/Account/Login">Đăng nhập ngay</a>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
