@model PharmaSphere.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PharmaSphere</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --primary-green: #7BCFA6;
            --primary-green-dark: #0d6849;
            --soft-green: #DFF5E8;
            --accent-red: #E74C3C;
            --dark-text: #1F2937;
            --light-text: #6B7280;
            --white: #FFFFFF;
            --border-color: #E5E7EB;
        }

        body, html {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .login-wrapper {
            min-height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(13, 104, 73, 0.8), rgba(13, 104, 73, 0.9)), 
                        url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            padding: 2rem 0;
        }

        .login-card {
            width: 100%;
            max-width: 600px; /* Increased width for Register */
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(15px);
            padding: 3.5rem 4rem;
            border-radius: 40px;
            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.35);
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo-box {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            background: var(--soft-green);
            border-radius: 20px;
            color: var(--primary-green-dark);
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            font-weight: 800;
            font-size: 0.85rem;
            margin-bottom: 0.6rem;
            color: var(--dark-text);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 1.5rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary-green-dark);
            width: 18px;
            height: 18px;
            z-index: 2;
        }

        .form-control {
            width: 100%;
            padding: 1rem 1.5rem 1rem 3.5rem; /* Icon inside */
            border: 2px solid var(--border-color);
            border-radius: 18px;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
            box-sizing: border-box;
            background: #fcfdfd;
            font-weight: 500;
        }

        .form-control:focus {
            border-color: var(--primary-green-dark);
            background: white;
            box-shadow: 0 0 0 6px rgba(13, 104, 73, 0.12);
        }

        .btn-submit {
            width: 100%;
            padding: 1.2rem;
            background: var(--primary-green-dark);
            color: white;
            border: none;
            border-radius: 18px;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 1rem;
            box-shadow: 0 10px 20px rgba(13, 104, 73, 0.2);
        }

        .btn-submit:hover {
            background: #0a523a;
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(13, 104, 73, 0.3);
        }

        .text-danger {
            color: var(--accent-red);
            font-size: 0.85rem;
            margin-top: 0.4rem;
            display: block;
            font-weight: 700;
        }

        .back-to-home {
            position: absolute;
            top: 3rem;
            left: 3rem;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 800;
            transition: all 0.3s;
            padding: 0.75rem 1.5rem;
            border-radius: 99px;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
        }

        .back-to-home:hover {
            background: rgba(255,255,255,0.25);
            transform: translateX(-8px);
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <a href="/" class="back-to-home">
            <i data-lucide="arrow-left"></i> Quay lại trang chủ
        </a>

        <div class="login-card">
            <div style="text-align: center;">
                <div class="logo-box">
                    <i data-lucide="user-plus" style="width: 36px; height: 36px;"></i>
                </div>
                <h2 style="font-size: 2.25rem; font-weight: 900; color: var(--dark-text); margin: 0; letter-spacing: -0.04em;">Tạo tài khoản mới</h2>
                <p style="color: var(--light-text); margin: 0.5rem 0 2.5rem; font-weight: 600; font-size: 1.05rem;">Bắt đầu hành trình chăm sóc sức khỏe cùng PharmaSphere</p>
            </div>

            <form asp-area="Customer" asp-controller="Account" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1.5rem; text-align: center;"></div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <div class="form-group">
                        <label>Họ và tên</label>
                        <div class="input-wrapper">
                            <i data-lucide="user"></i>
                            <input asp-for="FullName" class="form-control" placeholder="Họ và tên đầy đủ" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Địa chỉ Email</label>
                        <div class="input-wrapper">
                            <i data-lucide="mail"></i>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label>Tên đăng nhập</label>
                    <div class="input-wrapper">
                        <i data-lucide="at-sign"></i>
                        <input asp-for="Username" class="form-control" placeholder="Chọn tên đăng nhập duy nhất" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper">
                            <i data-lucide="lock"></i>
                            <input asp-for="Password" type="password" class="form-control" placeholder="********" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Xác nhận</label>
                        <div class="input-wrapper">
                            <i data-lucide="shield-check"></i>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="********" />
                        </div>
                    </div>
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <span asp-validation-for="Password" class="text-danger"></span>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit">Đăng ký ngay</button>
            </form>

            <div style="text-align: center; margin-top: 3rem; font-size: 1.1rem; color: var(--light-text); font-weight: 600;">
                Đã có tài khoản? <a href="/Account/Login" style="color: var(--primary-green-dark); text-decoration: none; font-weight: 900; border-bottom: 3px solid var(--soft-green); margin-left: 0.5rem;">Đăng nhập</a>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
