@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="login-container" style="max-width: 450px; margin: 4rem auto; padding: 2.5rem; background: var(--white); border-radius: 16px; box-shadow: var(--shadow-md);">
    <div style="text-align: center; margin-bottom: 2rem;">
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; background: var(--soft-green); border-radius: 50%; color: var(--primary-green-dark); margin-bottom: 1rem;">
            <i data-lucide="key-round" style="width: 32px; height: 32px;"></i>
        </div>
        <h2 style="font-size: 1.75rem; font-weight: 700; color: var(--dark-text); margin: 0;">Quên mật khẩu?</h2>
        <p style="color: var(--light-text); margin-top: 0.5rem;">Nhập email của bạn để nhận hướng dẫn khôi phục mật khẩu</p>
    </div>

    <form asp-controller="Account" asp-action="ForgotPassword" method="post">
        <div style="margin-bottom: 2rem;">
            <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--dark-text);">Email khôi phục</label>
            <div style="position: relative;">
                <div style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--light-text);">
                    <i data-lucide="mail" style="width: 18px; height: 18px;"></i>
                </div>
                <input type="email" name="email" required class="form-control" style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border: 1px solid var(--border-color); border-radius: 8px; outline: none;" placeholder="Nhập email của bạn" />
            </div>
        </div>

        <button type="submit" style="width: 100%; padding: 0.875rem; background: #0d6849; color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 1rem; cursor: pointer; transition: background 0.2s;">
            Gửi yêu cầu khôi phục
        </button>
    </form>
    
    <div style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: var(--light-text);">
        <a href="/Account/Login" style="color: var(--primary-green-dark); text-decoration: none; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Quay lại Đăng nhập
        </a>
    </div>
</div>

@section Scripts {
    <style>
        .form-control:focus {
            border-color: var(--primary-green-dark) !important;
            box-shadow: 0 0 0 3px rgba(123, 207, 166, 0.2);
        }
    </style>
}
