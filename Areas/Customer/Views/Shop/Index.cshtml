@model IEnumerable<PharmaSphere.Models.Product>

@{
    ViewData["Title"] = "Shop";
}

<div class="nav-container" style="padding-top: 3rem; padding-bottom: 5rem; display: grid; grid-template-columns: 300px 1fr; gap: 3rem; align-items: start;">
    <!-- Sidebar Filters -->
    <aside style="position: sticky; top: 100px;">
        <div style="background: white; padding: 2rem; border-radius: 16px; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 2rem;">Lọc sản phẩm</h2>

            <form action="/Shop" method="get">
                <input type="hidden" name="q" value="@ViewBag.SearchQuery" />
                
                <div style="margin-bottom: 2rem;">
                    <h3 style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; color: var(--light-text); margin-bottom: 1rem;">Danh mục</h3>
                    <select name="cat" 
                            style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--border-color); outline: none; cursor: pointer; font-family: inherit;">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                            @if (ViewBag.SelectedCategory == cat.Id)
                            {
                                <option value="@cat.Id" selected>@cat.Name</option>
                            }
                            else
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                </div>

                <div style="margin-bottom: 2rem;">
                    <h3 style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; color: var(--light-text); margin-bottom: 1rem;">Loại thuốc</h3>
                    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                        <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
                            <input type="radio" name="type" value="all" style="width: 18px; height: 18px; accent-color: var(--primary-green);" @(ViewBag.SelectedType == "all" || string.IsNullOrEmpty(ViewBag.SelectedType) ? "checked" : "") />
                            <span>Tất cả</span>
                        </label>
                        <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
                            <input type="radio" name="type" value="prescription" style="width: 18px; height: 18px; accent-color: var(--primary-green);" @(ViewBag.SelectedType == "prescription" ? "checked" : "") />
                            <span>Thuốc kê đơn</span>
                        </label>
                        <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
                            <input type="radio" name="type" value="non-prescription" style="width: 18px; height: 18px; accent-color: var(--primary-green);" @(ViewBag.SelectedType == "non-prescription" ? "checked" : "") />
                            <span>Không kê đơn</span>
                        </label>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem;">
                    <button type="submit" style="width: 100%; padding: 0.85rem; background: #0d6849; color: white; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 6px rgba(13, 104, 73, 0.2);">
                        Áp dụng lọc
                    </button>
                    <button type="button" onclick="location.href='/Shop'" style="width: 100%; padding: 0.85rem; background: white; color: var(--dark-text); border: 1px solid var(--border-color); border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s;">
                        Xóa lọc
                    </button>
                </div>
            </form>
        </div>
    </aside>

    <!-- Product Grid -->
    <section>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <h1 style="font-size: 2rem; font-weight: 700;">PharmaSphere - Kết quả tìm kiếm</h1>
            <span style="color: var(--light-text);">
                Hiển thị @( (ViewBag.CurrentPage - 1) * 4 + 1 ) - @( Math.Min(ViewBag.CurrentPage * 4, ViewBag.TotalItems) ) trong @ViewBag.TotalItems kết quả
            </span>
        </div>

        <div class="product-grid" style="grid-template-columns: repeat(2, 1fr);">
            @foreach (var product in Model)
            {
                <div class="product-card">
                    @if (product.IsPrescription)
                    {
                        <span class="badge-prescription">Kê đơn</span>
                    }
                    else
                    {
                        <span class="badge-new">Mới</span>
                    }
                    <a href="/Shop/Details/@product.Id">
                        <img src="@product.ImageUrl" class="product-image" alt="@product.Name" />
                    </a>
                    <div class="product-info">
                        <div class="product-brand">@product.Brand.Name</div>
                        <h3 class="product-name">
                            <a href="/Shop/Details/@product.Id" style="color: inherit; text-decoration: none;">@product.Name</a>
                        </h3>
                        <div class="product-rating">
                            <i data-lucide="star" style="fill: #fbbf24; width: 14px;"></i>
                            <i data-lucide="star" style="fill: #fbbf24; width: 14px;"></i>
                            <i data-lucide="star" style="fill: #fbbf24; width: 14px;"></i>
                            <i data-lucide="star" style="fill: #fbbf24; width: 14px;"></i>
                            <i data-lucide="star" style="width: 14px;"></i>
                            <span style="color: var(--light-text); margin-left: 5px;">(@product.Rating)</span>
                        </div>
                        <div class="product-price">@string.Format("{0:N0}₫", product.Price)</div>
                        
                        @if (product.IsPrescription)
                        {
                            <a href="/Shop/Details/@product.Id" class="btn-add-cart" style="background: white; color: #0d6849; border: 1px solid #0d6849; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                                <i data-lucide="file-text"></i>
                                Yêu cầu đơn thuốc
                            </a>
                        }
                        else
                        {
                            <button type="button" class="btn-add-cart" onclick="checkAuthAndAddToCart(@product.Id)">
                                <i data-lucide="shopping-cart"></i>
                                Thêm vào giỏ
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div style="display: flex; justify-content: center; margin-top: 4rem; gap: 0.5rem; align-items: center;">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?page=1&cat=@ViewBag.SelectedCategory&q=@ViewBag.SearchQuery&type=@ViewBag.SelectedType" class="page-btn">
                        <i data-lucide="chevrons-left" style="width: 16px;"></i>
                    </a>
                    <a href="?page=@(ViewBag.CurrentPage - 1)&cat=@ViewBag.SelectedCategory&q=@ViewBag.SearchQuery&type=@ViewBag.SelectedType" class="page-btn">
                        <i data-lucide="chevron-left" style="width: 16px;"></i>
                    </a>
                }

                @{
                    int startPage = Math.Max(1, ViewBag.CurrentPage - 1);
                    int endPage = Math.Min(ViewBag.TotalPages, startPage + 2);
                    if (endPage - startPage < 2) startPage = Math.Max(1, endPage - 2);
                }

                @if (startPage > 1)
                {
                    <a href="?page=1&cat=@ViewBag.SelectedCategory&q=@ViewBag.SearchQuery" class="page-btn">1</a>
                    @if (startPage > 2)
                    {
                        <span style="color: var(--light-text);">...</span>
                    }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a href="?page=@i&cat=@ViewBag.SelectedCategory&q=@ViewBag.SearchQuery" 
                       class="page-btn @(ViewBag.CurrentPage == i ? "active" : "")">
                        @i
                    </a>
                }

                @if (endPage < ViewBag.TotalPages)
                {
                    @if (endPage < ViewBag.TotalPages - 1)
                    {
                        <span style="color: var(--light-text);">...</span>
                    }
                    <a href="?page=@ViewBag.TotalPages&cat=@ViewBag.SelectedCategory&q=@ViewBag.SearchQuery" class="page-btn">@ViewBag.TotalPages</a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?page=@(ViewBag.CurrentPage + 1)&cat=@ViewBag.SelectedCategory&q=@ViewBag.SearchQuery" class="page-btn">
                        <i data-lucide="chevron-right" style="width: 16px;"></i>
                    </a>
                    <a href="?page=@ViewBag.TotalPages&cat=@ViewBag.SelectedCategory&q=@ViewBag.SearchQuery" class="page-btn">
                        <i data-lucide="chevrons-right" style="width: 16px;"></i>
                    </a>
                }
            </div>
        }
    </section>
</div>

<style>
    .page-btn {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: var(--dark-text);
        font-weight: 600;
        transition: all 0.2s;
    }

    .page-btn:hover {
        border-color: var(--primary-green);
        color: var(--primary-green);
    }

    .page-btn.active {
        background: #0d6849;
        border-color: #0d6849;
        color: white;
    }
</style>
