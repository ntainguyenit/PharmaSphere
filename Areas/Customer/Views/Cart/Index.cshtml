@model List<PharmaSphere.Models.CartItemViewModel>

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="nav-container" style="padding-top: 3rem; padding-bottom: 5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1 style="font-size: 2rem; font-weight: 800; margin: 0;">Giỏ hàng của bạn</h1>
        @if (Model.Count > 0)
        {
            <button onclick="confirmClearCart()" style="background: white; color: var(--accent-red); border: 1px solid var(--accent-red); padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s;" onmouseover="this.style.background='#fef2f2'" onmouseout="this.style.background='white'">
                <i data-lucide="trash-2" style="width: 18px;"></i>
                Xóa toàn bộ
            </button>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div style="text-align: center; padding: 4rem; background: white; border-radius: 16px; border: 1px solid var(--border-color);">
            <div style="color: var(--light-text); margin-bottom: 1rem;">
                <i data-lucide="shopping-cart" style="width: 48px; height: 48px; opacity: 0.5;"></i>
            </div>
            <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">Giỏ hàng đang trống</h2>
            <p style="color: var(--light-text); margin-bottom: 2rem;">Chưa có sản phẩm nào trong giỏ hàng của bạn.</p>
            <a href="/Shop" style="display: inline-block; padding: 0.875rem 2rem; background: var(--primary-green-dark); color: white; border-radius: 8px; text-decoration: none; font-weight: 600;">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 3rem;">
            <div>
                <div style="background: white; border-radius: 16px; border: 1px solid var(--border-color); overflow: hidden;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead style="background: #f8fafc; border-bottom: 1px solid var(--border-color);">
                            <tr>
                                <th style="padding: 1rem; text-align: left; font-weight: 600; color: var(--light-text); font-size: 0.9rem; text-transform: uppercase;">Sản phẩm</th>
                                <th style="padding: 1rem; text-align: center; font-weight: 600; color: var(--light-text); font-size: 0.9rem; text-transform: uppercase;">Số lượng</th>
                                <th style="padding: 1rem; text-align: right; font-weight: 600; color: var(--light-text); font-size: 0.9rem; text-transform: uppercase;">Tổng</th>
                                <th style="padding: 1rem;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr style="border-bottom: 1px solid var(--border-color);">
                                    <td style="padding: 1.5rem 1rem;">
                                        <div style="display: flex; align-items: center; gap: 1rem;">
                                            <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 64px; height: 64px; border-radius: 8px; object-fit: cover; border: 1px solid var(--border-color);" />
                                            <div>
                                                <div style="font-weight: 700; color: var(--dark-text); margin-bottom: 0.25rem;">@item.ProductName</div>
                                                <div style="color: var(--primary-green-dark); font-weight: 600; font-size: 0.9rem;">@string.Format("{0:N0}₫", item.Price)</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="padding: 1.5rem 1rem; text-align: center;">
                                        <form action="/Cart/Update" method="post" style="display: inline-flex; border: 1px solid var(--border-color); border-radius: 8px; overflow: hidden; background: white;">
                                            <input type="hidden" name="id" value="@item.ProductId" />
                                            <button type="submit" name="quantity" value="@(item.Quantity - 1)" style="width: 32px; height: 32px; border: none; background: transparent; cursor: pointer; color: var(--dark-text); font-weight: 600;">-</button>
                                            <input type="text" value="@item.Quantity" readonly style="width: 40px; text-align: center; border: none; outline: none; font-weight: 600;" />
                                            <button type="submit" name="quantity" value="@(item.Quantity + 1)" style="width: 32px; height: 32px; border: none; background: transparent; cursor: pointer; color: var(--dark-text); font-weight: 600;">+</button>
                                        </form>
                                    </td>
                                    <td style="padding: 1.5rem 1rem; text-align: right; font-weight: 700; color: var(--dark-text);">
                                        @string.Format("{0:N0}₫", item.Total)
                                    </td>
                                    <td style="padding: 1.5rem 1rem; text-align: center;">
                                        <form action="/Cart/Remove" method="post">
                                            <input type="hidden" name="id" value="@item.ProductId" />
                                            <button type="submit" style="background: transparent; border: none; color: var(--accent-red); cursor: pointer; padding: 0.5rem;" title="Xóa">
                                                <i data-lucide="trash-2" style="width: 18px;"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Summary -->
            <div>
                <div style="background: white; border-radius: 16px; border: 1px solid var(--border-color); padding: 2rem;">
                    <h2 style="font-size: 1.25rem; font-weight: 800; margin-bottom: 1.5rem;">Tóm tắt đơn hàng</h2>
                    
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; color: var(--light-text);">
                        <span>Tạm tính</span>
                        <span style="color: var(--dark-text); font-weight: 600;">@string.Format("{0:N0}₫", Model.Sum(i => i.Total))</span>
                    </div>
                    
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem; color: var(--light-text); border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
                        <span>Phí vận chuyển</span>
                        <span style="color: var(--dark-text); font-weight: 600;">Chưa tính</span>
                    </div>
                    
                    <div style="display: flex; justify-content: space-between; margin-bottom: 2rem; font-size: 1.25rem;">
                        <span style="font-weight: 700;">Tổng cộng</span>
                        <span style="font-weight: 800; color: var(--primary-green-dark);">@string.Format("{0:N0}₫", Model.Sum(i => i.Total))</span>
                    </div>

                    <a href="/Cart/Checkout" style="display: block; width: 100%; padding: 1rem; background: var(--primary-green-dark); color: white; border: none; border-radius: 8px; font-weight: 700; font-size: 1rem; cursor: pointer; text-align: center; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#0a523a'" onmouseout="this.style.background='var(--primary-green-dark)'">
                        Tiến hành thanh toán
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmClearCart() {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: "Bạn có chắc chắn muốn xóa toàn bộ sản phẩm trong giỏ hàng?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Có, xóa hết!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Cart/Clear';
                }
            });
        }

        // Add loading state to checkout button
        const checkoutBtn = document.querySelector('a[href="/Cart/Checkout"]');
        if (checkoutBtn) {
            checkoutBtn.addEventListener('click', function(e) {
                Swal.fire({
                    title: 'Đang chuẩn bị...',
                    didOpen: () => {
                        Swal.showLoading()
                    },
                    allowOutsideClick: false,
                    showConfirmButton: false,
                    timer: 500
                });
            });
        }
    </script>
}
