@model List<PharmaSphere.Models.CartItemViewModel>

@{
    ViewData["Title"] = "Thanh toán";
}

<div class="nav-container" style="padding-top: 3rem; padding-bottom: 5rem;">
    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 2rem;">Thanh toán</h1>

    <div style="display: grid; grid-template-columns: 1fr 400px; gap: 4rem;">
        <!-- Left: Shipping Info -->
        <div>
            <div style="background: white; border-radius: 16px; border: 1px solid var(--border-color); padding: 2.5rem; margin-bottom: 2rem;">
                <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem;">
                    <i data-lucide="truck" style="color: var(--primary-green-dark);"></i>
                    Thông tin giao hàng
                </h2>

                <form asp-action="PlaceOrder" method="post" id="checkoutForm">
                    @Html.AntiForgeryToken()
                    
                    <div style="margin-bottom: 1.5rem;">
                        <label for="fullName" style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--dark-text);">Họ và tên</label>
                        <input type="text" id="fullName" value="@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value" readonly style="width: 100%; padding: 0.875rem; border: 1px solid var(--border-color); border-radius: 8px; background: #f8fafc; color: #64748b;" />
                    </div>

                    <div style="margin-bottom: 1.5rem;">
                        <label for="phone" style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--dark-text);">Số điện thoại</label>
                        <input type="text" name="phone" id="phone" required style="width: 100%; padding: 0.875rem; border: 1px solid var(--border-color); border-radius: 8px; outline: none;" placeholder="Nhập số điện thoại nhận hàng" />
                    </div>

                    <div style="margin-bottom: 1.5rem;">
                        <label for="address" style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--dark-text);">Địa chỉ giao hàng</label>
                        <textarea name="address" id="address" required rows="3" style="width: 100%; padding: 0.875rem; border: 1px solid var(--border-color); border-radius: 8px; outline: none; font-family: inherit;" placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
                    </div>

                    <h2 style="font-size: 1.5rem; font-weight: 700; margin: 3rem 0 2rem; display: flex; align-items: center; gap: 0.75rem;">
                        <i data-lucide="credit-card" style="color: var(--primary-green-dark);"></i>
                        Phương thức thanh toán
                    </h2>

                    <div style="display: grid; gap: 1rem;">
                        <label style="display: flex; align-items: center; gap: 1rem; padding: 1.25rem; border: 1px solid var(--border-color); border-radius: 12px; cursor: pointer; transition: all 0.2s;" class="payment-option">
                            <input type="radio" name="paymentMethod" value="COD" checked style="width: 20px; height: 20px; accent-color: var(--primary-green-dark);" />
                            <div>
                                <div style="font-weight: 700; color: var(--dark-text);">Thanh toán khi nhận hàng (COD)</div>
                                <div style="font-size: 0.85rem; color: var(--light-text);">Giao hàng và thu tiền tận nơi</div>
                            </div>
                        </label>

                        <label style="display: flex; align-items: center; gap: 1rem; padding: 1.25rem; border: 1px solid var(--border-color); border-radius: 12px; cursor: pointer; transition: all 0.2s;" class="payment-option">
                            <input type="radio" name="paymentMethod" value="Banking" style="width: 20px; height: 20px; accent-color: var(--primary-green-dark);" />
                            <div>
                                <div style="font-weight: 700; color: var(--dark-text);">Chuyển khoản ngân hàng</div>
                                <div style="font-size: 0.85rem; color: var(--light-text);">Thanh toán qua mã QR hoặc STK</div>
                            </div>
                        </label>
                    </div>
                </form>
            </div>
        </div>

        <!-- Right: Order Summary -->
        <aside>
            <div style="background: white; border-radius: 16px; border: 1px solid var(--border-color); padding: 2rem; position: sticky; top: 100px;">
                <h2 style="font-size: 1.25rem; font-weight: 800; margin-bottom: 1.5rem;">Sản phẩm đã chọn</h2>
                
                <div style="max-height: 300px; overflow-y: auto; margin-bottom: 1.5rem; padding-right: 0.5rem;">
                    @foreach (var item in Model)
                    {
                        <div style="display: flex; gap: 1rem; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid #f1f5f9;">
                            <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 50px; height: 50px; border-radius: 6px; object-fit: cover;" />
                            <div style="flex: 1;">
                                <div style="font-size: 0.9rem; font-weight: 600; color: var(--dark-text); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@item.ProductName</div>
                                <div style="font-size: 0.85rem; color: var(--light-text);">SL: @item.Quantity</div>
                            </div>
                            <div style="font-weight: 700; font-size: 0.9rem; color: var(--dark-text);">@string.Format("{0:N0}₫", item.Total)</div>
                        </div>
                    }
                </div>

                <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; color: var(--light-text);">
                    <span>Tạm tính</span>
                    <span style="color: var(--dark-text); font-weight: 600;">@string.Format("{0:N0}₫", Model.Sum(i => i.Total))</span>
                </div>
                
                <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem; color: var(--light-text);">
                    <span>Phí vận chuyển</span>
                    <span style="color: var(--primary-green-dark); font-weight: 600;">Miễn phí</span>
                </div>
                
                <div style="display: flex; justify-content: space-between; margin-bottom: 2rem; font-size: 1.25rem; border-top: 2px dashed var(--border-color); pt: 1.5rem;">
                    <span style="font-weight: 700; margin-top: 1rem;">Tổng thanh toán</span>
                    <span style="font-weight: 800; color: var(--primary-green-dark); margin-top: 1rem;">@string.Format("{0:N0}₫", Model.Sum(i => i.Total))</span>
                </div>

                <button type="submit" form="checkoutForm" style="width: 100%; padding: 1.125rem; background: var(--primary-green-dark); color: white; border: none; border-radius: 8px; font-weight: 700; font-size: 1.125rem; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#0a523a'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--primary-green-dark)'; this.style.transform='translateY(0)'">
                    Đặt hàng ngay
                </button>
                
                <p style="text-align: center; color: var(--light-text); font-size: 0.85rem; margin-top: 1.5rem;">
                    Bằng việc đặt hàng, bạn đồng ý với <a href="#" style="color: var(--primary-green-dark); text-decoration: none;">Điều khoản dịch vụ</a> của PharmaSphere.
                </p>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        // Simple visual feedback for radio selections
        const options = document.querySelectorAll('.payment-option');
        options.forEach(opt => {
            opt.addEventListener('click', () => {
                options.forEach(o => o.style.borderColor = 'var(--border-color)');
                opt.style.borderColor = 'var(--primary-green-dark)';
                opt.style.background = '#f0fdf4';
            });
        });
        
        // Select first one by default
        document.querySelector('.payment-option input[checked]').parentElement.style.borderColor = 'var(--primary-green-dark)';
        document.querySelector('.payment-option input[checked]').parentElement.style.background = '#f0fdf4';

        // Order placement confirmation
        document.getElementById('checkoutForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const phone = document.getElementById('phone').value;
            const address = document.getElementById('address').value;

            if (!phone || !address) {
                Swal.fire({
                    icon: 'error',
                    title: 'Thiếu thông tin',
                    text: 'Vui lòng điền đầy đủ số điện thoại và địa chỉ giao hàng!'
                });
                return;
            }

            Swal.fire({
                title: 'Xác nhận đặt hàng?',
                text: "Bạn có chắc chắn muốn đặt đơn hàng này?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0d6849',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Xác nhận đặt hàng',
                cancelButtonText: 'Kiểm tra lại'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Đang xử lý đơn hàng...',
                        didOpen: () => {
                            Swal.showLoading()
                        },
                        allowOutsideClick: false,
                        showConfirmButton: false
                    });
                    this.submit();
                }
            });
        });
    </script>
}
