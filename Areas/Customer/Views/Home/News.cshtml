@{
    ViewData["Title"] = "Tin tức & Sức khỏe";
}

<div style="background: #f8fafc; padding-bottom: 5rem;">
    <!-- Featured Hero Article -->
    <section style="background: white; padding: 4rem 0; border-bottom: 1px solid var(--border-color);">
        <div class="nav-container">
            <div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 4rem; align-items: center;">
                <div style="position: relative;">
                    <img src="https://images.unsplash.com/photo-1559839734-2b71f1e3c770?auto=format&fit=crop&q=80&w=1200" style="width: 100%; height: 500px; object-fit: cover; border-radius: 32px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);" />
                    <div style="position: absolute; bottom: 2rem; left: 2rem; right: 2rem; background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); padding: 2rem; border-radius: 20px;">
                        <span style="color: var(--primary-green-dark); font-weight: 700; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">Chuyên gia tư vấn</span>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--dark-text); margin: 0.75rem 0; line-height: 1.2;">Cẩm nang chăm sóc hệ hô hấp khi thời tiết giao mùa</h2>
                        <div style="display: flex; align-items: center; gap: 1rem; color: var(--light-text); font-size: 0.9rem;">
                            <span style="display: flex; align-items: center; gap: 0.4rem;"><i data-lucide="calendar" style="width: 16px;"></i> 09/05/2024</span>
                            <span style="display: flex; align-items: center; gap: 0.4rem;"><i data-lucide="user" style="width: 16px;"></i> DS. Minh Phương</span>
                        </div>
                    </div>
                </div>
                
                <div>
                    <h3 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 2px solid var(--primary-green);">Tin mới nhất</h3>
                    <div style="display: flex; flex-direction: column; gap: 2rem;">
                        @for(int i=1; i<=3; i++) {
                            <div style="display: flex; gap: 1.25rem;">
                                <img src="https://images.unsplash.com/photo-1505751172107-573967a4dddc?auto=format&fit=crop&q=80&w=300" style="width: 100px; height: 100px; object-fit: cover; border-radius: 12px;" />
                                <div style="flex: 1;">
                                    <h4 style="margin: 0; font-size: 1rem; font-weight: 700; line-height: 1.4; color: var(--dark-text); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">Cách bổ sung Vitamin đúng cách cho người trưởng thành</h4>
                                    <span style="font-size: 0.8rem; color: var(--light-text); margin-top: 0.5rem; display: block;">2 giờ trước</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- News Categories -->
    <div class="nav-container" style="padding: 2rem 0;">
        <div style="display: flex; gap: 1rem; overflow-x: auto; padding-bottom: 1rem;">
            <button style="padding: 0.75rem 1.5rem; background: var(--primary-green-dark); color: white; border: none; border-radius: 99px; font-weight: 700; white-space: nowrap;">Tất cả bài viết</button>
            <button style="padding: 0.75rem 1.5rem; background: white; color: var(--dark-text); border: 1px solid var(--border-color); border-radius: 99px; font-weight: 600; white-space: nowrap;">Kiến thức dược phẩm</button>
            <button style="padding: 0.75rem 1.5rem; background: white; color: var(--dark-text); border: 1px solid var(--border-color); border-radius: 99px; font-weight: 600; white-space: nowrap;">Mẹo chăm sóc sức khỏe</button>
            <button style="padding: 0.75rem 1.5rem; background: white; color: var(--dark-text); border: 1px solid var(--border-color); border-radius: 99px; font-weight: 600; white-space: nowrap;">Review sản phẩm</button>
            <button style="padding: 0.75rem 1.5rem; background: white; color: var(--dark-text); border: 1px solid var(--border-color); border-radius: 99px; font-weight: 600; white-space: nowrap;">Thông báo hệ thống</button>
        </div>
    </div>

    <!-- Article Grid -->
    <div class="nav-container">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2.5rem;">
            @for(int i=1; i<=6; i++) {
                <article style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-8px)'" onmouseout="this.style.transform='translateY(0)'">
                    <img src="https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&q=80&w=800" style="width: 100%; height: 220px; object-fit: cover;" />
                    <div style="padding: 1.5rem;">
                        <span style="color: var(--primary-green); font-weight: 700; font-size: 0.8rem; text-transform: uppercase;">Sống khỏe mỗi ngày</span>
                        <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--dark-text); margin: 0.75rem 0; line-height: 1.4;">Tác hại của việc lạm dụng thuốc kháng sinh không theo chỉ dẫn</h3>
                        <p style="color: var(--light-text); font-size: 0.95rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">Kháng sinh là vũ khí quan trọng trong điều trị bệnh nhiễm khuẩn, tuy nhiên việc tự ý mua và sử dụng đang gây ra những hệ lụy nghiêm trọng cho sức khỏe...</p>
                        <div style="margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
                            <a href="#" style="color: var(--primary-green-dark); font-weight: 700; text-decoration: none; font-size: 0.9rem;">Đọc tiếp <i data-lucide="chevron-right" style="width: 16px; vertical-align: middle;"></i></a>
                            <span style="color: var(--light-text); font-size: 0.8rem;">5 phút đọc</span>
                        </div>
                    </div>
                </article>
            }
        </div>
        
        <!-- Load More -->
        <div style="text-align: center; margin-top: 4rem;">
            <button style="padding: 1rem 3rem; background: white; color: var(--primary-green-dark); border: 2px solid var(--primary-green-dark); border-radius: 12px; font-weight: 700; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='var(--primary-green-dark)'; this.style.color='white'" onmouseout="this.style.background='white'; this.style.color='var(--primary-green-dark)'">Xem thêm bài viết</button>
        </div>
    </div>

    <!-- Newsletter Section -->
    <div class="nav-container" style="margin-top: 5rem;">
        <div style="background: var(--primary-green-dark); border-radius: 32px; padding: 4rem; display: flex; align-items: center; justify-content: space-between; color: white; gap: 3rem;">
            <div style="max-width: 500px;">
                <h2 style="font-size: 2.25rem; font-weight: 800; margin-bottom: 1rem;">Nhận thông tin sức khỏe hữu ích nhất</h2>
                <p style="opacity: 0.8; font-size: 1.1rem;">Đăng ký nhận bản tin hàng tuần từ các chuyên gia dược lý hàng đầu của PharmaSphere.</p>
            </div>
            <div style="flex: 1; max-width: 450px;">
                <form style="display: flex; gap: 1rem; background: rgba(255,255,255,0.1); padding: 0.5rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.2);">
                    <input type="email" placeholder="Email của bạn" style="flex: 1; background: transparent; border: none; padding: 1rem; color: white; outline: none; font-size: 1rem;" />
                    <button style="background: white; color: #0d6849; border: none; padding: 1rem 2rem; border-radius: 12px; font-weight: 700; cursor: pointer;">Đăng ký</button>
                </form>
                <p style="font-size: 0.75rem; opacity: 0.6; margin-top: 1rem; text-align: center;">Chúng tôi cam kết không spam và bảo mật thông tin của bạn.</p>
            </div>
        </div>
    </div>
</div>
