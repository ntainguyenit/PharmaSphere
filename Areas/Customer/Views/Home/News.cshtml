@{
    ViewData["Title"] = "Tin tức & Sức khỏe";
}

<div style="background: #fcfdfe; padding-bottom: 6rem;">
    <!-- Featured Hero Article -->
    <section style="background: white; padding: 5rem 0; border-bottom: 1px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);">
        <div class="nav-container">
            <div style="display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 5rem; align-items: start;">
                <div style="position: relative;">
                    <img src="https://images.unsplash.com/photo-1559839734-2b71f1e3c770?auto=format&fit=crop&q=80&w=1200" style="width: 100%; height: 550px; object-fit: cover; border-radius: 40px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.12);" />
                    <div style="position: absolute; bottom: 2.5rem; left: 2.5rem; right: 2.5rem; background: rgba(255,255,255,0.95); backdrop-filter: blur(15px); padding: 2.5rem; border-radius: 24px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);">
                        <span style="color: var(--primary-green-dark); font-weight: 800; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 0.1em; display: inline-block; margin-bottom: 0.75rem;">Chuyên gia tư vấn</span>
                        <h2 style="font-size: 2.25rem; font-weight: 800; color: var(--dark-text); margin: 0.5rem 0; line-height: 1.2;">Cẩm nang chăm sóc hệ hô hấp khi thời tiết giao mùa</h2>
                        <div style="display: flex; align-items: center; gap: 1.5rem; color: var(--light-text); font-size: 0.95rem; margin-top: 1.5rem;">
                            <span style="display: flex; align-items: center; gap: 0.5rem;"><i data-lucide="calendar" style="width: 18px;"></i> 09/05/2024</span>
                            <span style="display: flex; align-items: center; gap: 0.5rem;"><i data-lucide="user" style="width: 18px;"></i> DS. Minh Phương</span>
                        </div>
                    </div>
                </div>
                
                <div style="background: white; padding: 2rem; border-radius: 24px; border: 1px solid var(--border-color);">
                    <h3 style="font-size: 1.6rem; font-weight: 800; margin-bottom: 2rem; padding-bottom: 1.25rem; border-bottom: 3px solid var(--primary-green); color: var(--dark-text);">Tin mới nhất</h3>
                    <div style="display: flex; flex-direction: column; gap: 2.5rem;">
                        <div style="display: flex; gap: 1.5rem; align-items: center;">
                            <img src="https://images.unsplash.com/photo-1505751172107-573967a4dddc?auto=format&fit=crop&q=80&w=300" style="width: 110px; height: 110px; object-fit: cover; border-radius: 16px;" />
                            <div style="flex: 1;">
                                <h4 style="margin: 0; font-size: 1.05rem; font-weight: 700; line-height: 1.4; color: var(--dark-text);">Cách bổ sung Vitamin đúng cách cho người trưởng thành</h4>
                                <span style="font-size: 0.85rem; color: var(--light-text); margin-top: 0.75rem; display: block; font-weight: 600;">2 giờ trước</span>
                            </div>
                        </div>
                        <div style="display: flex; gap: 1.5rem; align-items: center;">
                                <img src="https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?auto=format&fit=crop&q=80&w=300" style="width: 110px; height: 110px; object-fit: cover; border-radius: 16px;" />
                            <div style="flex: 1;">
                                <h4 style="margin: 0; font-size: 1.05rem; font-weight: 700; line-height: 1.4; color: var(--dark-text);">Tầm quan trọng của việc kiểm tra sức khỏe định kỳ</h4>
                                <span style="font-size: 0.85rem; color: var(--light-text); margin-top: 0.75rem; display: block; font-weight: 600;">5 giờ trước</span>
                            </div>
                        </div>
                        <div style="display: flex; gap: 1.5rem; align-items: center;">
                                <img src="https://images.unsplash.com/photo-1550572017-ed200f5e6343?auto=format&fit=crop&q=80&w=300" style="width: 110px; height: 110px; object-fit: cover; border-radius: 16px;" />
                            <div style="flex: 1;">
                                <h4 style="margin: 0; font-size: 1.05rem; font-weight: 700; line-height: 1.4; color: var(--dark-text);">Mẹo sử dụng máy đo huyết áp tại nhà chính xác nhất</h4>
                                <span style="font-size: 0.85rem; color: var(--light-text); margin-top: 0.75rem; display: block; font-weight: 600;">1 ngày trước</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Article Grid -->
    <div class="nav-container" style="padding-top: 5rem;">
        <h2 style="font-size: 2.25rem; font-weight: 800; color: var(--dark-text); margin-bottom: 3.5rem; text-align: center;">Tất cả bài viết</h2>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem;">
            <article style="background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                <img src="https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&q=80&w=800" style="width: 100%; height: 240px; object-fit: cover;" />
                <div style="padding: 2rem;">
                    <span style="color: var(--primary-green); font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Sống khỏe</span>
                    <h3 style="font-size: 1.35rem; font-weight: 800; color: var(--dark-text); margin: 1rem 0; line-height: 1.4;">Tác hại của việc lạm dụng thuốc kháng sinh</h3>
                    <p style="color: var(--light-text); font-size: 1rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">Kháng sinh là vũ khí quan trọng trong điều trị bệnh nhiễm khuẩn, tuy nhiên việc tự ý mua và sử dụng đang gây ra những hệ lụy...</p>
                    <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
                        <a href="#" style="color: var(--primary-green-dark); font-weight: 800; text-decoration: none;">Đọc tiếp <i data-lucide="arrow-right" style="width: 18px; vertical-align: middle; margin-left: 5px;"></i></a>
                        <span style="color: var(--light-text); font-size: 0.85rem; font-weight: 600;">5 phút đọc</span>
                    </div>
                </div>
            </article>

            <article style="background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                <img src="https://images.unsplash.com/photo-1532938911079-1b06ac7ceec7?auto=format&fit=crop&q=80&w=800" style="width: 100%; height: 240px; object-fit: cover;" />
                <div style="padding: 2rem;">
                    <span style="color: #3b82f6; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Dược phẩm</span>
                    <h3 style="font-size: 1.35rem; font-weight: 800; color: var(--dark-text); margin: 1rem 0; line-height: 1.4;">Phân biệt thuốc chính hãng và thuốc giả</h3>
                    <p style="color: var(--light-text); font-size: 1rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">Trong bối cảnh thị trường dược phẩm phức tạp, người tiêu dùng cần trang bị kiến thức để nhận biết sản phẩm thuốc thật...</p>
                    <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
                        <a href="#" style="color: var(--primary-green-dark); font-weight: 800; text-decoration: none;">Đọc tiếp <i data-lucide="arrow-right" style="width: 18px; vertical-align: middle; margin-left: 5px;"></i></a>
                        <span style="color: var(--light-text); font-size: 0.85rem; font-weight: 600;">7 phút đọc</span>
                    </div>
                </div>
            </article>

            <article style="background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                <img src="https://images.unsplash.com/photo-1511174511562-5f7f18b874f8?auto=format&fit=crop&q=80&w=800" style="width: 100%; height: 240px; object-fit: cover;" />
                <div style="padding: 2rem;">
                    <span style="color: #f59e0b; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;">Mẹ & Bé</span>
                    <h3 style="font-size: 1.35rem; font-weight: 800; color: var(--dark-text); margin: 1rem 0; line-height: 1.4;">Chế độ dinh dưỡng cho trẻ nhỏ trong mùa hè</h3>
                    <p style="color: var(--light-text); font-size: 1rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">Mùa hè nắng nóng dễ khiến trẻ bị mất nước và chán ăn. Phụ huynh cần chú ý bổ sung thực phẩm thanh nhiệt...</p>
                    <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
                        <a href="#" style="color: var(--primary-green-dark); font-weight: 800; text-decoration: none;">Đọc tiếp <i data-lucide="arrow-right" style="width: 18px; vertical-align: middle; margin-left: 5px;"></i></a>
                        <span style="color: var(--light-text); font-size: 0.85rem; font-weight: 600;">4 phút đọc</span>
                    </div>
                </div>
            </article>
        </div>
    </div>
</div>
