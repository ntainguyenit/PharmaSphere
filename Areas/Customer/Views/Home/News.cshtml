@{
    ViewData["Title"] = "News";
}

<div class="hero-section" style="padding: 4rem 0; background: linear-gradient(rgba(13, 104, 73, 0.9), rgba(13, 104, 73, 0.8)), url('https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&q=80&w=2000');">
    <div class="hero-content">
        <h1 class="hero-title" style="font-size: 3rem;">PharmaSphere News</h1>
        <p class="hero-subtitle">Stay updated with the latest health trends, medical breakthroughs, and company updates.</p>
    </div>
</div>

<div class="container" style="max-width: 1200px; margin: 4rem auto; padding: 0 1.5rem;">
    <div style="text-align: center; margin-bottom: 4rem;">
        <h2 style="font-size: 2.5rem; font-weight: 800; color: var(--dark-text);">Latest Updates</h2>
        <div style="width: 60px; height: 4px; background: var(--primary-green); margin: 1rem auto;"></div>
    </div>

    <div style="background: white; padding: 4rem; border-radius: 20px; box-shadow: var(--shadow-md); text-align: center;">
        <i data-lucide="newspaper" style="width: 64px; height: 64px; color: var(--primary-green-dark); margin-bottom: 2rem;"></i>
        <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 1rem;">Our News Portal is Under Construction</h2>
        <p style="color: var(--light-text); font-size: 1.1rem; max-width: 600px; margin: 0 auto;">We are working hard to bring you the most relevant health news and insights. Stay tuned for our upcoming blog and news section.</p>
        <div style="margin-top: 3rem;">
            <a href="/" class="btn-primary" style="background: transparent; color: var(--primary-green-dark); border: 2px solid var(--primary-green-dark);">Back to Home</a>
        </div>
    </div>
</div>
