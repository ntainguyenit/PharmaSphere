@{
    ViewData["Title"] = "Promotions";
}

<div class="hero-section" style="padding: 4rem 0; background: linear-gradient(rgba(13, 104, 73, 0.9), rgba(13, 104, 73, 0.8)), url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&q=80&w=2000');">
    <div class="hero-content">
        <h1 class="hero-title" style="font-size: 3rem;">Special Promotions</h1>
        <p class="hero-subtitle">Discover our latest deals and exclusive offers on healthcare products.</p>
    </div>
</div>

<div class="container" style="max-width: 1200px; margin: 4rem auto; padding: 0 1.5rem; text-align: center;">
    <div style="background: white; padding: 4rem; border-radius: 20px; box-shadow: var(--shadow-md);">
        <i data-lucide="ticket" style="width: 64px; height: 64px; color: var(--primary-green-dark); margin-bottom: 2rem;"></i>
        <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 1rem;">Coming Soon!</h2>
        <p style="color: var(--light-text); font-size: 1.1rem; max-width: 600px; margin: 0 auto;">We're currently preparing some amazing deals just for you. Check back soon to save big on your favorite pharmacy items.</p>
        <div style="margin-top: 3rem;">
            <a href="/Shop" class="btn-primary">Browse Shop</a>
        </div>
    </div>
</div>
