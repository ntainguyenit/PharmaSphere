@{
    ViewData["Title"] = "Chương trình Khuyến mãi";
}

<section style="background: linear-gradient(135deg, rgba(13, 104, 73, 0.9), rgba(13, 104, 73, 0.95)), url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&q=80&w=2000'); background-size: cover; background-position: center; padding: 7rem 0; color: white; position: relative; overflow: hidden; text-align: center;">
    <div style="position: absolute; top: -50px; right: -50px; width: 300px; height: 300px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>
    
    <div class="nav-container" style="position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center;">
        <span style="background: #fbbf24; color: #78350f; padding: 0.6rem 1.5rem; border-radius: 99px; font-weight: 800; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.1em; display: inline-block;">Đại tiệc ưu đãi tháng 5</span>
        <h1 style="font-size: 4.5rem; font-weight: 800; margin: 2rem 0; line-height: 1.1; letter-spacing: -0.02em;">Săn Deal Hời <br/>Chăm Sóc Sức Khỏe Vàng</h1>
        <p style="font-size: 1.3rem; opacity: 0.9; margin-bottom: 3.5rem; line-height: 1.6; max-width: 800px;">Giảm giá lên đến 50% cho hàng ngàn sản phẩm chăm sóc sức khỏe, vitamin và thiết bị y tế gia đình.</p>
        <div style="display: flex; gap: 1.5rem; justify-content: center;">
            <a href="#flash-sale" style="background: white; color: #0d6849; padding: 1.25rem 3.5rem; border-radius: 14px; text-decoration: none; font-weight: 800; font-size: 1.1rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">Săn Deal Ngay</a>
            <a href="#coupons" style="background: rgba(255,255,255,0.15); color: white; padding: 1.25rem 3rem; border-radius: 14px; text-decoration: none; font-weight: 800; font-size: 1.1rem; border: 1.5px solid rgba(255,255,255,0.3); backdrop-filter: blur(8px); transition: all 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.25)'" onmouseout="this.style.background='rgba(255,255,255,0.15)'">Mã Giảm Giá</a>
        </div>
    </div>
</section>

<div class="nav-container" style="padding: 6rem 1.5rem; max-width: 1200px; margin: 0 auto;">
    <!-- Flash Sale Section -->
    <div id="flash-sale" style="margin-bottom: 7rem; text-align: center;">
        <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 4rem;">
            <h2 style="font-size: 2.75rem; font-weight: 800; color: var(--dark-text); display: flex; align-items: center; gap: 1rem; margin: 0;">
                <i data-lucide="zap" style="fill: #f59e0b; color: #f59e0b; width: 40px; height: 40px;"></i> Flash Sale Cuối Tuần
            </h2>
            <div style="display: flex; align-items: center; gap: 1.25rem; margin-top: 1.5rem; background: #fef2f2; padding: 1rem 2rem; border-radius: 20px; border: 1px solid #fee2e2;">
                <span style="color: #ef4444; font-weight: 800; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.05em;">Kết thúc sau:</span>
                <div id="countdown" style="display: flex; gap: 0.75rem; align-items: center;">
                    <div class="time-box" style="background: #ef4444; color: white; padding: 0.6rem 0.8rem; border-radius: 10px; font-weight: 800; min-width: 45px; font-size: 1.25rem;"><span id="hours">08</span></div>
                    <span style="color: #ef4444; font-weight: 900; font-size: 1.5rem;">:</span>
                    <div class="time-box" style="background: #ef4444; color: white; padding: 0.6rem 0.8rem; border-radius: 10px; font-weight: 800; min-width: 45px; font-size: 1.25rem;"><span id="minutes">45</span></div>
                    <span style="color: #ef4444; font-weight: 900; font-size: 1.5rem;">:</span>
                    <div class="time-box" style="background: #ef4444; color: white; padding: 0.6rem 0.8rem; border-radius: 10px; font-weight: 800; min-width: 45px; font-size: 1.25rem;"><span id="seconds">22</span></div>
                </div>
            </div>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; text-align: left;">
            @for(int i=1; i<=3; i++) {
                <div style="background: white; border-radius: 28px; border: 1px solid var(--border-color); overflow: hidden; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);" onmouseover="this.style.transform='translateY(-15px)'; this.style.boxShadow='0 25px 50px -12px rgba(0,0,0,0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 6px -1px rgba(0,0,0,0.05)';">
                    <div style="position: relative;">
                        <span style="position: absolute; top: 1.5rem; left: 1.5rem; background: #ef4444; color: white; padding: 0.6rem 1.2rem; border-radius: 12px; font-weight: 800; font-size: 0.95rem; z-index: 1;">-@(i*15)%</span>
                        <img src="https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?auto=format&fit=crop&q=80&w=600" style="width: 100%; height: 280px; object-fit: cover;" />
                    </div>
                    <div style="padding: 2rem;">
                        <span style="color: var(--light-text); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Dược Phẩm Hoa Linh</span>
                        <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--dark-text); margin: 0.75rem 0; line-height: 1.4; min-height: 3.5rem;">Thực phẩm bảo vệ sức khỏe Vitamin C 1000mg</h3>
                        <div style="display: flex; align-items: center; gap: 1rem; margin: 1.25rem 0;">
                            <span style="font-size: 1.5rem; font-weight: 900; color: #ef4444;">189.000đ</span>
                            <span style="font-size: 1rem; color: var(--light-text); text-decoration: line-through;">250.000đ</span>
                        </div>
                        <div style="background: #fee2e2; height: 10px; border-radius: 6px; position: relative; margin-bottom: 2rem;">
                            <div style="position: absolute; left: 0; top: 0; height: 100%; width: @(85 - i*10)%; background: linear-gradient(to right, #ef4444, #f87171); border-radius: 6px;"></div>
                            <span style="position: absolute; left: 0; top: -1.5rem; font-size: 0.8rem; color: #ef4444; font-weight: 800;">Đã bán @(85 - i*10)%</span>
                        </div>
                        <button onclick="checkAuthAndAddToCart(1)" style="width: 100%; padding: 1rem; background: #0d6849; color: white; border: none; border-radius: 14px; font-weight: 800; font-size: 1.05rem; cursor: pointer; transition: all 0.3s;">Mua Ngay</button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Coupons Section (Centered) -->
    <div id="coupons" style="margin-bottom: 7rem;">
        <h2 style="font-size: 2.75rem; font-weight: 800; color: var(--dark-text); margin-bottom: 4rem; text-align: center;">Mã Giảm Giá Độc Quyền</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 2.5rem;">
            <div style="background: #fff; border: 3px dashed #0d6849; border-radius: 24px; display: flex; overflow: hidden; position: relative; box-shadow: 0 10px 25px rgba(0,0,0,0.05);">
                <div style="background: #0d6849; color: white; padding: 2.5rem; display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 140px;">
                    <span style="font-size: 2.2rem; font-weight: 900;">50K</span>
                    <span style="font-size: 0.85rem; opacity: 0.9; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">Giảm</span>
                </div>
                <div style="padding: 2rem; flex: 1;">
                    <h4 style="margin: 0; font-size: 1.3rem; font-weight: 800; color: var(--dark-text);">Đơn hàng từ 500K</h4>
                    <p style="font-size: 0.95rem; color: var(--light-text); margin: 0.75rem 0 1.5rem;">Hạn dùng: 31/05/2026</p>
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <input type="text" id="coupon1" value="PHARMA50" readonly style="flex: 1; padding: 0.75rem; border: 2px solid var(--border-color); border-radius: 10px; font-family: monospace; font-weight: 800; text-align: center; background: #f8fafc; color: #0d6849; font-size: 1.1rem; width: 0;" />
                        <button onclick="copyToClipboard('coupon1', this)" style="background: #0d6849; color: white; border: none; padding: 0.75rem 1.25rem; border-radius: 10px; font-size: 0.9rem; font-weight: 800; cursor: pointer; white-space: nowrap; transition: all 0.2s;">Sao chép</button>
                    </div>
                </div>
            </div>
            
            <div style="background: #fff; border: 3px dashed #fbbf24; border-radius: 24px; display: flex; overflow: hidden; position: relative; box-shadow: 0 10px 25px rgba(0,0,0,0.05);">
                <div style="background: #fbbf24; color: #78350f; padding: 2.5rem; display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 140px;">
                    <span style="font-size: 2.2rem; font-weight: 900;">FREE</span>
                    <span style="font-size: 0.85rem; opacity: 0.9; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">Ship</span>
                </div>
                <div style="padding: 2rem; flex: 1;">
                    <h4 style="margin: 0; font-size: 1.3rem; font-weight: 800; color: var(--dark-text);">Đơn hàng từ 300K</h4>
                    <p style="font-size: 0.95rem; color: var(--light-text); margin: 0.75rem 0 1.5rem;">Áp dụng toàn quốc</p>
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                        <input type="text" id="coupon2" value="FREESHIP" readonly style="flex: 1; padding: 0.75rem; border: 2px solid var(--border-color); border-radius: 10px; font-family: monospace; font-weight: 800; text-align: center; background: #f8fafc; color: #78350f; font-size: 1.1rem; width: 0;" />
                        <button onclick="copyToClipboard('coupon2', this)" style="background: #0d6849; color: white; border: none; padding: 0.75rem 1.25rem; border-radius: 10px; font-size: 0.9rem; font-weight: 800; cursor: pointer; white-space: nowrap; transition: all 0.2s;">Sao chép</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Countdown Timer Logic
    function updateCountdown() {
        let hoursElem = document.getElementById('hours');
        let minutesElem = document.getElementById('minutes');
        let secondsElem = document.getElementById('seconds');
        
        if (!hoursElem) return;

        let hours = parseInt(hoursElem.innerText);
        let minutes = parseInt(minutesElem.innerText);
        let seconds = parseInt(secondsElem.innerText);

        if (seconds > 0) {
            seconds--;
        } else {
            if (minutes > 0) {
                minutes--;
                seconds = 59;
            } else {
                if (hours > 0) {
                    hours--;
                    minutes = 59;
                    seconds = 59;
                }
            }
        }

        hoursElem.innerText = hours.toString().padStart(2, '0');
        minutesElem.innerText = minutes.toString().padStart(2, '0');
        secondsElem.innerText = seconds.toString().padStart(2, '0');
    }

    setInterval(updateCountdown, 1000);

    // Copy to clipboard with anti-spam cooldown
    let copyCooldowns = {};

    function copyToClipboard(id, btn) {
        const now = Date.now();
        if (copyCooldowns[id] && now - copyCooldowns[id] < 5000) {
            const wait = Math.ceil((5000 - (now - copyCooldowns[id])) / 1000);
            if (typeof showNotification === 'function') {
                showNotification('error', 'Chờ một chút', `Vui lòng đợi ${wait} giây để tiếp tục.`);
            }
            return;
        }

        const copyText = document.getElementById(id);
        copyText.select();
        copyText.setSelectionRange(0, 99999);
        
        navigator.clipboard.writeText(copyText.value).then(() => {
            copyCooldowns[id] = Date.now();
            const originalText = btn.innerText;
            btn.innerText = 'Đã chép!';
            btn.style.background = '#059669';
            btn.disabled = true;

            if (typeof showNotification === 'function') {
                showNotification('success', 'Thành công', 'Đã sao chép mã: ' + copyText.value);
            }

            setTimeout(() => {
                btn.innerText = originalText;
                btn.style.background = '#0d6849';
                btn.disabled = false;
            }, 5000);
        });
    }
</script>
