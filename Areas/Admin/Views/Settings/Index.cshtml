@model IEnumerable<PharmaSphere.Models.SystemSetting>
@{
    ViewData["Title"] = "Cài đặt hệ thống";
    Layout = "_AdminLayout";
}

<div style="padding: 2rem; max-width: 900px; margin: 0 auto;">
    <div style="margin-bottom: 2rem;">
        <h1 style="font-size: 1.875rem; font-weight: 700; color: var(--dark-text); margin-bottom: 0.5rem;">Cài đặt hệ thống</h1>
        <p style="color: #6b7280;">Cấu hình các thông số vận hành của nhà thuốc PharmaSphere.</p>
    </div>

    <form asp-action="SaveSettings" method="post">
        @Html.AntiForgeryToken()
        
        <div style="background: white; border-radius: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #f3f4f6; overflow: hidden;">
            <div style="padding: 1.5rem 2rem; border-bottom: 1px solid #f3f4f6; background: #fafafa;">
                <h3 style="font-size: 1.125rem; font-weight: 600; color: var(--dark-text); display: flex; align-items: center; gap: 0.75rem;">
                    <i data-lucide="settings-2" style="width: 20px; color: var(--primary-green);"></i>
                    Thông tin chung
                </h3>
            </div>

            <div style="padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
                @foreach (var setting in Model)
                {
                    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; align-items: center;">
                        <div>
                            <label style="display: block; font-weight: 600; color: #374151; margin-bottom: 0.25rem;">@setting.Description</label>
                            <span style="font-size: 0.75rem; color: #9ca3af;">@setting.Key</span>
                        </div>
                        <input type="text" name="settings[@setting.Key]" value="@setting.Value" style="width: 100%; padding: 0.75rem; border-radius: 10px; border: 1px solid #e5e7eb; outline: none; transition: all 0.2s;" onfocus="this.style.borderColor='var(--primary-green)'; this.style.boxShadow='0 0 0 3px rgba(16, 185, 129, 0.1)'" onblur="this.style.borderColor='#e5e7eb'; this.style.boxShadow='none'" />
                    </div>
                }
            </div>

            <div style="padding: 1.5rem 2rem; background: #fafafa; border-top: 1px solid #f3f4f6; display: flex; justify-content: flex-end; gap: 1rem;">
                <button type="reset" style="padding: 0.75rem 1.5rem; border-radius: 10px; border: 1px solid #d1d5db; background: white; font-weight: 600; cursor: pointer; color: #374151;">
                    Hủy bỏ
                </button>
                <button type="submit" style="padding: 0.75rem 2rem; border-radius: 10px; border: none; background: #064E3B; color: white; font-weight: 600; cursor: pointer; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
                    Lưu cấu hình
                </button>
            </div>
        </div>
    </form>
</div>
