@model IEnumerable<PharmaSphere.Models.User>
@using PharmaSphere.Models
@{
    ViewData["Title"] = "Quản lý nhân viên";
}

<div class="content-header" style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1 style="font-size: 1.8rem; font-weight: 800; color: var(--dark-text); margin: 0;">@ViewData["Title"]</h1>
        <p style="color: var(--light-text); margin: 0.25rem 0 0;">Quản lý đội ngũ nhân viên và quản trị viên</p>
    </div>
    <button class="btn-primary" style="background: #064E3B; border-radius: 8px; padding: 0.75rem 1.5rem; border: none; color: white; display: flex; align-items: center; gap: 0.5rem; font-weight: 700; cursor: pointer; box-shadow: none !important;">
        <i data-lucide="user-plus" style="width: 20px;"></i> Thêm nhân viên mới
    </button>
</div>

<style>
    /* Allow natural scrolling */
    body {
        overflow: auto !important;
    }

    .main-content {
        height: auto !important;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: visible !important;
    }

    .table-container-card {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: white;
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        margin-bottom: 2rem;
    }

    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    
    table {
        min-width: 800px;
    }
</style>

<div class="filter-bar admin-card" style="margin-bottom: 2rem;">
    <form method="get" class="filter-form">
        <div style="position: relative; flex: 1; display: flex; align-items: center;">
            <i data-lucide="search" style="position: absolute; left: 1rem; color: var(--light-text); width: 18px;"></i>
            <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tìm theo tên, email hoặc username..." style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border: 1px solid var(--border-color); border-radius: 8px; outline: none;" />
        </div>
        <button type="submit" style="padding: 0.75rem 2rem; background: var(--soft-green); color: var(--primary-green-dark); border: 1px solid var(--primary-green-dark); border-radius: 8px; font-weight: 600; cursor: pointer;">Lọc</button>
        <a href="/Admin/Employees" style="padding: 0.75rem; color: var(--light-text); display: flex; align-items: center;" title="Xóa bộ lọc">
            <i data-lucide="rotate-ccw" style="width: 20px;"></i>
        </a>
    </form>
</div>

<div class="admin-card table-container-card">
    <div class="table-responsive">
        <table style="width: 100%; border-collapse: separate; border-spacing: 0; text-align: left;">
            <thead style="position: sticky; top: 0; z-index: 10; background: var(--bg-light); box-shadow: 0 1px 0 var(--border-color);">
                <tr>
                    <th style="padding: 1.25rem 1.5rem; font-weight: 700; color: var(--dark-text); font-size: 0.9rem;">Nhân viên</th>
                    <th style="padding: 1.25rem 1.5rem; font-weight: 700; color: var(--dark-text); font-size: 0.9rem;">Vai trò</th>
                    <th style="padding: 1.25rem 1.5rem; font-weight: 700; color: var(--dark-text); font-size: 0.9rem;">Liên hệ</th>
                    <th style="padding: 1.25rem 1.5rem; font-weight: 700; color: var(--dark-text); font-size: 0.9rem; text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.2s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='transparent'">
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <div style="width: 40px; height: 40px; border-radius: 50%; background: @(item.Role == UserRole.Admin ? "#fee2e2" : "#dcfce7"); color: @(item.Role == UserRole.Admin ? "#991b1b" : "#166534"); display: flex; align-items: center; justify-content: center; font-weight: 700;">
                                    <i data-lucide="@(item.Role == UserRole.Admin ? "shield-check" : "user")" style="width: 18px;"></i>
                                </div>
                                <div>
                                    <div style="font-weight: 600; color: var(--dark-text);">@item.FullName</div>
                                    <div style="font-size: 0.75rem; color: var(--light-text);">@@@item.Username</div>
                                </div>
                            </div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            @if (item.Role == UserRole.Admin)
                            {
                                <span style="padding: 0.25rem 0.75rem; background: #fee2e2; color: #991b1b; border-radius: 20px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Administrator</span>
                            }
                            else
                            {
                                <span style="padding: 0.25rem 0.75rem; background: #dcfce7; color: #166534; border-radius: 20px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Staff Member</span>
                            }
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="font-size: 0.9rem; color: var(--dark-text);">@item.Email</div>
                            <div style="font-size: 0.8rem; color: var(--light-text);">@(item.Phone ?? "N/A")</div>
                        </td>
                        <td style="padding: 1.25rem 1.5rem;">
                            <div style="display: flex; justify-content: center; gap: 1rem;">
                                <a href="#" style="color: #3b82f6;" title="Chỉnh sửa quyền">
                                    <i data-lucide="edit-3" style="width: 18px;"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa nhân viên này?')" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" style="background: none; border: none; color: var(--accent-red); cursor: pointer; padding: 0;">
                                        <i data-lucide="trash-2" style="width: 18px;"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div style="padding: 1.5rem; border-top: 1px solid var(--border-color); display: flex; justify-content: center; align-items: center; gap: 0.5rem; background: #f8f9fa;">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="@Url.Action("Index", new { page = i, searchTerm = ViewBag.SearchTerm })" 
                   style="padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 600; min-width: 40px; text-align: center;
                          @(i == ViewBag.CurrentPage ? "background: var(--primary-green-dark); color: white;" : "background: white; border: 1px solid var(--border-color); color: var(--dark-text);")">
                    @i
                </a>
            }
        </div>
    }
</div>
