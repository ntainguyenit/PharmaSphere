<div style="padding: 4rem 2rem; text-align: center; background: white; border-radius: 16px; box-shadow: var(--shadow-sm); margin-top: 2rem;">
    <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; background: var(--soft-green); border-radius: 50%; color: var(--primary-green-dark); margin-bottom: 1.5rem;">
        <i data-lucide="users" style="width: 40px; height: 40px;"></i>
    </div>
    <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem; color: var(--dark-text);">@ViewData["Title"]</h2>
    <p style="color: var(--light-text); font-size: 1.1rem; max-width: 500px; margin: 0 auto;">Dữ liệu khách hàng đang được đồng bộ hóa. Tính năng sẽ sẵn sàng sớm.</p>
    <div style="margin-top: 2.5rem;">
        <a href="/Admin" style="padding: 0.75rem 2rem; background: var(--primary-green-dark); color: white; text-decoration: none; border-radius: 8px; font-weight: 600;">Quay lại Dashboard</a>
    </div>
</div>
