@model PharmaSphere.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id.ToString("D5");
}

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <a href="/Admin/Orders" style="display: flex; align-items: center; gap: 0.5rem; color: var(--light-text); text-decoration: none; font-size: 0.9rem; margin-bottom: 0.5rem;">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Quay lại danh sách
        </a>
        <h2 style="font-size: 1.75rem; font-weight: 700; color: var(--dark-text); margin: 0;">@ViewData["Title"]</h2>
    </div>
    <div style="display: flex; gap: 1rem;">
        <button class="btn-secondary" style="display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1.25rem;">
            <i data-lucide="printer" style="width: 18px; height: 18px;"></i> In hóa đơn
        </button>
        <form action="/Admin/Orders/UpdateStatus" method="post" style="display: inline;">
            <input type="hidden" name="id" value="@Model.Id" />
            <select name="status" onchange="this.form.submit()" style="padding: 0.6rem 1.25rem; border-radius: 8px; border: 1px solid #e2e8f0; background: white; font-weight: 600; color: var(--dark-text); outline: none; cursor: pointer;">
                <option value="0" selected="@(Model.Status == OrderStatus.Pending)">Chờ xử lý</option>
                <option value="1" selected="@(Model.Status == OrderStatus.Confirmed)">Đã xác nhận</option>
                <option value="2" selected="@(Model.Status == OrderStatus.Shipping)">Đang giao</option>
                <option value="3" selected="@(Model.Status == OrderStatus.Delivered)">Thành công</option>
                <option value="4" selected="@(Model.Status == OrderStatus.Cancelled)">Đã hủy</option>
            </select>
        </form>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start;">
    <!-- Left Column: Items and Info -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
        <!-- Order Items -->
        <div style="background: white; border-radius: 16px; box-shadow: var(--shadow-sm); overflow: hidden;">
            <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-color); background: #f8fafc;">
                <h3 style="margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--dark-text);">Sản phẩm trong đơn hàng</h3>
            </div>
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border-color); text-align: left;">
                        <th style="padding: 1rem 1.5rem; font-size: 0.85rem; color: var(--light-text); text-transform: uppercase;">Sản phẩm</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.85rem; color: var(--light-text); text-transform: uppercase;">Đơn giá</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.85rem; color: var(--light-text); text-transform: uppercase; text-align: center;">Số lượng</th>
                        <th style="padding: 1rem 1.5rem; font-size: 0.85rem; color: var(--light-text); text-transform: uppercase; text-align: right;">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr style="border-bottom: 1px solid var(--border-color);">
                            <td style="padding: 1rem 1.5rem;">
                                <div style="display: flex; align-items: center; gap: 1rem;">
                                    <img src="@item.Product.ImageUrl" style="width: 48px; height: 48px; border-radius: 8px; object-fit: cover; border: 1px solid #e2e8f0;" />
                                    <div>
                                        <div style="font-weight: 600; color: var(--dark-text);">@item.Product.Name</div>
                                        <div style="font-size: 0.75rem; color: var(--light-text);">Mã: PROD-@item.ProductId.ToString("D3")</div>
                                    </div>
                                </div>
                            </td>
                            <td style="padding: 1rem 1.5rem; color: var(--dark-text);">@item.Price.ToString("N0") ₫</td>
                            <td style="padding: 1rem 1.5rem; text-align: center; color: var(--dark-text);">@item.Quantity</td>
                            <td style="padding: 1rem 1.5rem; text-align: right; font-weight: 700; color: var(--dark-text);">
                                @((item.Price * item.Quantity).ToString("N0")) ₫
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            <div style="padding: 1.5rem; background: #f8fafc; display: flex; flex-direction: column; align-items: flex-end; gap: 0.75rem;">
                <div style="display: flex; justify-content: space-between; width: 250px; color: var(--light-text);">
                    <span>Tạm tính:</span>
                    <span>@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
                <div style="display: flex; justify-content: space-between; width: 250px; color: var(--light-text);">
                    <span>Phí vận chuyển:</span>
                    <span>Miễn phí</span>
                </div>
                <div style="display: flex; justify-content: space-between; width: 250px; font-size: 1.25rem; font-weight: 800; color: var(--primary-green-dark); border-top: 2px solid #e2e8f0; padding-top: 0.75rem; margin-top: 0.5rem;">
                    <span>Tổng cộng:</span>
                    <span>@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
            </div>
        </div>

        <!-- Billing Info -->
        <div style="background: white; border-radius: 16px; box-shadow: var(--shadow-sm); padding: 1.5rem;">
            <h3 style="margin-top: 0; margin-bottom: 1.25rem; font-size: 1.1rem; font-weight: 700; color: var(--dark-text); display: flex; align-items: center; gap: 0.5rem;">
                <i data-lucide="credit-card" style="width: 20px; height: 20px; color: var(--primary-green);"></i> Thông tin thanh toán
            </h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div>
                    <div style="font-size: 0.85rem; color: var(--light-text); margin-bottom: 0.25rem;">Phương thức thanh toán</div>
                    <div style="font-weight: 600; color: var(--dark-text);">@Model.PaymentMethod</div>
                </div>
                <div>
                    <div style="font-size: 0.85rem; color: var(--light-text); margin-bottom: 0.25rem;">Trạng thái thanh toán</div>
                    <div style="display: inline-flex; align-items: center; gap: 0.5rem; color: #166534; font-weight: 600;">
                        <span style="width: 8px; height: 8px; background: #22c55e; border-radius: 50%;"></span> Đã thanh toán
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Customer & Shipping -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
        <!-- Customer Card -->
        <div style="background: white; border-radius: 16px; box-shadow: var(--shadow-sm); padding: 1.5rem;">
            <h3 style="margin-top: 0; margin-bottom: 1.25rem; font-size: 1.1rem; font-weight: 700; color: var(--dark-text); display: flex; align-items: center; gap: 0.5rem;">
                <i data-lucide="user" style="width: 20px; height: 20px; color: var(--primary-green);"></i> Khách hàng
            </h3>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                <div style="width: 48px; height: 48px; background: var(--soft-green); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--primary-green-dark); font-size: 1.25rem;">
                    @Model.Customer.FullName.Substring(0, 1)
                </div>
                <div>
                    <div style="font-weight: 700; color: var(--dark-text);">@Model.Customer.FullName</div>
                    <div style="font-size: 0.85rem; color: var(--light-text);">ID: #@Model.CustomerId.ToString("D3")</div>
                </div>
            </div>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <i data-lucide="mail" style="width: 16px; height: 16px; color: #94a3b8;"></i>
                    <span style="font-size: 0.9rem; color: var(--dark-text);">@Model.Customer.Email</span>
                </div>
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <i data-lucide="phone" style="width: 16px; height: 16px; color: #94a3b8;"></i>
                    <span style="font-size: 0.9rem; color: var(--dark-text);">@Model.Phone</span>
                </div>
            </div>
        </div>

        <!-- Shipping Address -->
        <div style="background: white; border-radius: 16px; box-shadow: var(--shadow-sm); padding: 1.5rem;">
            <h3 style="margin-top: 0; margin-bottom: 1.25rem; font-size: 1.1rem; font-weight: 700; color: var(--dark-text); display: flex; align-items: center; gap: 0.5rem;">
                <i data-lucide="map-pin" style="width: 20px; height: 20px; color: var(--primary-green);"></i> Địa chỉ nhận hàng
            </h3>
            <p style="font-size: 0.95rem; color: var(--dark-text); line-height: 1.6; margin: 0;">
                @Model.Address
            </p>
        </div>

        <!-- Order Timeline -->
        <div style="background: white; border-radius: 16px; box-shadow: var(--shadow-sm); padding: 1.5rem;">
            <h3 style="margin-top: 0; margin-bottom: 1.25rem; font-size: 1.1rem; font-weight: 700; color: var(--dark-text);">Lịch sử đơn hàng</h3>
            <div style="display: flex; flex-direction: column; gap: 1.5rem; position: relative; padding-left: 1rem;">
                <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: #e2e8f0; margin-left: 3px;"></div>
                
                <div style="position: relative;">
                    <div style="position: absolute; left: -14px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: #22c55e; border: 2px solid white;"></div>
                    <div style="font-size: 0.85rem; font-weight: 700; color: var(--dark-text);">Đã đặt hàng</div>
                    <div style="font-size: 0.75rem; color: var(--light-text);">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                @if (Model.Status != OrderStatus.Pending && Model.Status != OrderStatus.Cancelled)
                {
                    <div style="position: relative;">
                        <div style="position: absolute; left: -14px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: #22c55e; border: 2px solid white;"></div>
                        <div style="font-size: 0.85rem; font-weight: 700; color: var(--dark-text);">Đã xác nhận</div>
                        <div style="font-size: 0.75rem; color: var(--light-text);">@Model.OrderDate.AddMinutes(15).ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }

                @if (Model.Status == OrderStatus.Shipping || Model.Status == OrderStatus.Delivered)
                {
                    <div style="position: relative;">
                        <div style="position: absolute; left: -14px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: #22c55e; border: 2px solid white;"></div>
                        <div style="font-size: 0.85rem; font-weight: 700; color: var(--dark-text);">Đang giao hàng</div>
                        <div style="font-size: 0.75rem; color: var(--light-text);">@Model.OrderDate.AddHours(2).ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }

                @if (Model.Status == OrderStatus.Delivered)
                {
                    <div style="position: relative;">
                        <div style="position: absolute; left: -14px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: #22c55e; border: 2px solid white;"></div>
                        <div style="font-size: 0.85rem; font-weight: 700; color: var(--dark-text);">Giao hàng thành công</div>
                        <div style="font-size: 0.75rem; color: var(--light-text);">@Model.OrderDate.AddDays(1).ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }

                @if (Model.Status == OrderStatus.Cancelled)
                {
                    <div style="position: relative;">
                        <div style="position: absolute; left: -14px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: #ef4444; border: 2px solid white;"></div>
                        <div style="font-size: 0.85rem; font-weight: 700; color: #ef4444;">Đã hủy đơn hàng</div>
                        <div style="font-size: 0.75rem; color: var(--light-text);">@Model.OrderDate.AddHours(1).ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
